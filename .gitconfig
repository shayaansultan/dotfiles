[user]
	name = Shayaan Sultan
	email = sultan.shayaan@gmail.com

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	dark = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[alias]
	co = checkout
	wl = worktree list
	wr = worktree remove --force
	get = !git fetch --all --prune && git pull
	f = !git fetch --all --prune && git pull
	p = push
	cm = commit -m
